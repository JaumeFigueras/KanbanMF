# Copy this file to .env and fill in the values.
# .env is git-ignored and must never be committed.

# Application
APP_NAME = KanbanMF
FRONTEND_URL = http://localhost:5173

# Database — async psycopg3 driver URL
# Format: postgresql+psycopg://user:password@host:port/dbname
DATABASE_URL = postgresql+psycopg://kanbanmf_user:CHANGE_ME@localhost:5432/kanbanmf

# JWT
SECRET_KEY = CHANGE_ME_USE_openssl_rand_-hex_32
ALGORITHM = HS256
ACCESS_TOKEN_EXPIRE_MINUTES = 15

# Google OAuth (leave empty to disable Google login)
GOOGLE_CLIENT_ID =
GOOGLE_CLIENT_SECRET =
GOOGLE_REDIRECT_URI = http://localhost:8000/api/v1/auth/google/callback
GOOGLE_AUTH_URL = https://accounts.google.com/o/oauth2/v2/auth
GOOGLE_TOKEN_URL = https://oauth2.googleapis.com/token
GOOGLE_USERINFO_URL = https://openidconnect.googleapis.com/v1/userinfo

# SMTP / Email — port 465 uses SSL/TLS directly (smtps)
SMTP_HOST = authsmtp.securemail.pro
SMTP_PORT = 465
SMTP_USERNAME = CHANGE_ME
SMTP_PASSWORD = CHANGE_ME
SMTP_FROM_EMAIL = CHANGE_ME
SMTP_FROM_NAME = KanbanMF
